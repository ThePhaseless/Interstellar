{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Cluster Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(longhorn_node_storage_capacity_bytes)",
          "legendFormat": "Total Capacity",
          "refId": "A"
        }
      ],
      "title": "Total Capacity",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(longhorn_node_storage_usage_bytes)",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "title": "Total Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(longhorn_node_storage_reservation_bytes)",
          "legendFormat": "Reserved",
          "refId": "A"
        }
      ],
      "title": "Total Reserved",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(longhorn_node_storage_usage_bytes) / sum(longhorn_node_storage_capacity_bytes)",
          "legendFormat": "Usage",
          "refId": "A"
        }
      ],
      "title": "Cluster Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "longhorn_node_count_total",
          "legendFormat": "Nodes",
          "refId": "A"
        }
      ],
      "title": "Node Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "count(longhorn_disk_status{condition=\"schedulable\"} == 1)",
          "legendFormat": "Schedulable",
          "refId": "A"
        }
      ],
      "title": "Schedulable Disks",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "title": "Node Storage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "longhorn_node_storage_usage_bytes / longhorn_node_storage_capacity_bytes",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ],
      "title": "Node Storage Usage %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "normal" },
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*Capacity.*" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 0 },
              {
                "id": "custom.lineStyle",
                "value": { "dash": [10, 10], "fill": "dash" }
              },
              { "id": "custom.stacking", "value": { "mode": "none" } },
              {
                "id": "color",
                "value": { "fixedColor": "white", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*Used.*" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*Reserved.*" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "longhorn_node_storage_usage_bytes",
          "legendFormat": "{{ node }} Used",
          "refId": "A"
        },
        {
          "expr": "longhorn_node_storage_reservation_bytes",
          "legendFormat": "{{ node }} Reserved",
          "refId": "B"
        },
        {
          "expr": "longhorn_node_storage_capacity_bytes",
          "legendFormat": "{{ node }} Capacity",
          "refId": "C"
        }
      ],
      "title": "Node Storage Breakdown",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "title": "Disk Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "No" },
                "1": { "color": "green", "text": "Yes" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Capacity" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Reserved" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Ready" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Schedulable" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Node" }]
      },
      "targets": [
        {
          "expr": "longhorn_disk_capacity_bytes",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "longhorn_disk_usage_bytes",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "expr": "longhorn_disk_reservation_bytes",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "expr": "longhorn_disk_status{condition=\"ready\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        },
        {
          "expr": "longhorn_disk_status{condition=\"schedulable\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "E"
        }
      ],
      "title": "Disk Status",
      "type": "table",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "node" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "__name__ 5": true,
              "condition": true,
              "condition 1": true,
              "condition_reason": true,
              "condition_reason 1": true,
              "disk": true,
              "disk 1": true,
              "disk 2": true,
              "disk 3": true,
              "disk 4": true
            },
            "renameByName": {
              "Value #A": "Capacity",
              "Value #B": "Used",
              "Value #C": "Reserved",
              "Value #D": "Ready",
              "Value #E": "Schedulable",
              "node": "Node"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "title": "Volumes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Capacity" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Actual Size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Usage %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              {
                "id": "custom.cellOptions",
                "value": { "mode": "gradient", "type": "gauge" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.7 },
                    { "color": "red", "value": 0.85 }
                  ]
                }
              },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Robustness" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": { "color": "red", "text": "Degraded" },
                      "1": { "color": "green", "text": "Healthy" },
                      "2": { "color": "orange", "text": "Faulted" }
                    },
                    "type": "value"
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": { "color": "yellow", "text": "Detached" },
                      "1": { "color": "blue", "text": "Attaching" },
                      "2": { "color": "green", "text": "Attached" },
                      "3": { "color": "red", "text": "Detaching" }
                    },
                    "type": "value"
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Usage %" }]
      },
      "targets": [
        {
          "expr": "longhorn_volume_capacity_bytes",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "longhorn_volume_actual_size_bytes",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "longhorn_volume_actual_size_bytes / longhorn_volume_capacity_bytes",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "longhorn_volume_robustness",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "longhorn_volume_state",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "title": "Volume Details",
      "type": "table",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "pvc" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "__name__ 5": true,
              "node": true,
              "node 1": true,
              "node 2": true,
              "node 3": true,
              "node 4": true,
              "volume": true,
              "volume 1": true,
              "volume 2": true,
              "volume 3": true,
              "volume 4": true
            },
            "indexByName": {
              "pvc": 0,
              "pvc_namespace": 1,
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "Value #D": 5,
              "Value #E": 6
            },
            "renameByName": {
              "Value #A": "Capacity",
              "Value #B": "Actual Size",
              "Value #C": "Usage %",
              "Value #D": "Robustness",
              "Value #E": "State",
              "pvc": "PVC",
              "pvc_namespace": "Namespace"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "title": "Volume I/O",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "longhorn_volume_read_iops{pvc!=\"\"}",
          "legendFormat": "{{ pvc }} read",
          "refId": "A"
        },
        {
          "expr": "longhorn_volume_write_iops{pvc!=\"\"}",
          "legendFormat": "{{ pvc }} write",
          "refId": "B"
        }
      ],
      "title": "Volume IOPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "longhorn_volume_read_throughput{pvc!=\"\"}",
          "legendFormat": "{{ pvc }} read",
          "refId": "A"
        },
        {
          "expr": "longhorn_volume_write_throughput{pvc!=\"\"}",
          "legendFormat": "{{ pvc }} write",
          "refId": "B"
        }
      ],
      "title": "Volume Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "longhorn_volume_read_latency{pvc!=\"\"}",
          "legendFormat": "{{ pvc }} read",
          "refId": "A"
        },
        {
          "expr": "longhorn_volume_write_latency{pvc!=\"\"}",
          "legendFormat": "{{ pvc }} write",
          "refId": "B"
        }
      ],
      "title": "Volume Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(longhorn_snapshot_actual_size_bytes) by (pvc)",
          "legendFormat": "{{ pvc }}",
          "refId": "A"
        }
      ],
      "title": "Snapshot Size by Volume",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["longhorn", "storage"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Longhorn Storage",
  "uid": "longhorn-storage"
}
