{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "kubernetes": {
    "fileMatch": ["(^|/)Kubernetes/.+\\.ya?ml$"]
  },
  "packageRules": [
    {
      "description": "Ignore legacy LinuxServer qBittorrent tags",
      "matchManagers": [
        "kubernetes"
      ],
      "matchPackageNames": [
        "linuxserver/qbittorrent"
      ],
      "allowedVersions": "^(?!20\\.).*"
    },
    {
      "automerge": true,
      "groupName": "All non-major dependencies",
      "groupSlug": "all-minor-patch",
      "ignoreTests": true,
      "matchPackageNames": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ]
}
