# 1. Load Nix flake devShell (provides all CLI tools)
use flake

# 2. Load .env file if it exists (e.g. BWS_ACCESS_TOKEN)
dotenv_if_exists

# 3. Python venv: create via uv sync if missing, then activate
export UV_PYTHON_PREFERENCE=managed
if [[ ! -d .venv ]]; then
  log_status "creating virtualenv via uv sync"
  uv sync --quiet
fi
source .venv/bin/activate

# 4. Source Bitwarden secrets when BWS_ACCESS_TOKEN is available
if [[ -n "${BWS_ACCESS_TOKEN:-}" ]]; then
  source_env scripts/setup-env.sh
else
  log_status "BWS_ACCESS_TOKEN not set – skipping secrets setup (run 'source scripts/setup-env.sh' manually)"
fi
